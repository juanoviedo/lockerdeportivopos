{
  "name": "deportes-pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node backup_auto.js && next dev",
    "dev:setup": "node backup_auto.js && prisma db push && npm run seed",
    "seed": "node prisma/seed.js",
    "build": "node backup_auto.js && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "tunnel": "npx localtunnel --port 3000",
    "db:push": "node backup_auto.js && prisma db push",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "backup": "node backup_auto.js",
    "sync:staging": "node sync_environments.js local staging",
    "sync:production": "node sync_environments.js staging production",
    "sync:clear-staging": "node sync_environments.js local staging --clear",
    "sync:clear-production": "node sync_environments.js staging production --clear",
    "deploy:staging": "npm run backup && git push origin main:staging",
    "deploy:production": "npm run backup && git push origin main"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "next": "16.2.2",
    "nodemailer": "^8.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.19.3",
    "typescript": "^5"
  }
}