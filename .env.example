# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================
# Este archivo es una plantilla. Usa:
# - .env.local para desarrollo local
# - .env.staging para staging (Supabase)
# - .env.production para producción (Supabase)

# Database
# LOCAL: PostgreSQL en tu máquina
# STAGING/PROD: Supabase
DATABASE_URL="postgresql://usuario:contraseña@host:puerto/basedatos"
DIRECT_URL="postgresql://usuario:contraseña@host:puerto/basedatos"

# Security
JWT_SECRET="tu-secret-key-aqui"

# Email Configuration (Nodemailer)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="tu-email@gmail.com"
EMAIL_SERVER_PASSWORD="tu-contraseña-aplicacion"
EMAIL_FROM='"Soporte Deportes POS" <tu-email@gmail.com>'

# Application
NEXT_PUBLIC_APP_NAME="Deportes POS"
ENVIRONMENT="local|staging|production"
